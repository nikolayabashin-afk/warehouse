generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  WORKER
  VIEWER
}

enum MovementType {
  RECEIVE
  ISSUE
  MOVE
  ADJUST
}

enum TaskType {
  INCOMING
}

enum TaskStatus {
  OPEN
  COMPLETED
  CANCELLED
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  passwordHash   String
  role           Role            @default(VIEWER)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  movements      Movement[]
  createdTasks   WarehouseTask[] @relation("TaskCreator")
  completedTasks WarehouseTask[] @relation("TaskCompleter")
}

model Product {
  id                String              @id @default(cuid())
  sku               String              @unique
  name              String
  manufacturer      String?
  model             String?
  category          String?
  preferredLocation String?
  lastLocation      String?
  archived          Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  inventory         Inventory[]
  movements         Movement[]
  tasks             WarehouseTask[]
  taskLines         WarehouseTaskLine[]
}

model Location {
  id          String              @id @default(cuid())
  code        String              @unique
  zone        String?
  type        String              @default("PERMANENT")
  capacity    Int?
  active      Boolean             @default(true)
  note        String?
  createdAt   DateTime            @default(now())
  inventory   Inventory[]
  fromMoves   Movement[]          @relation("FromLocation")
  toMoves     Movement[]          @relation("ToLocation")
  taskTargets WarehouseTask[]
  lineTargets WarehouseTaskLine[]
}

model Inventory {
  id          String   @id @default(cuid())
  productId   String
  locationId  String
  qty         Int      @default(0)
  batch       String?
  expiryDate  DateTime?
  note        String?
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id])
  location    Location @relation(fields: [locationId], references: [id])

  @@unique([productId, locationId, batch])
  @@index([locationId])
  @@index([productId])
}

model Movement {
  id             String       @id @default(cuid())
  type           MovementType
  productId      String
  fromLocationId String?
  toLocationId   String?
  qty            Int
  note           String?
  createdAt      DateTime     @default(now())
  userId         String?
  product        Product      @relation(fields: [productId], references: [id])
  fromLocation   Location?    @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation     Location?    @relation("ToLocation", fields: [toLocationId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([productId])
}

model WarehouseTask {
  id                  String              @id @default(cuid())
  type                TaskType            @default(INCOMING)
  status              TaskStatus          @default(OPEN)
  buyer               String?
  documentNumber      String?
  documentDate        DateTime?
  note                String?
  targetLocationId    String?
  createdById         String?
  completedById       String?
  completedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Legacy single-line fields kept optional for safe migration of older data.
  productId           String?
  expectedQty         Int?
  articleNumber       String?
  productNameSnapshot String?

  product             Product?            @relation(fields: [productId], references: [id])
  targetLocation      Location?           @relation(fields: [targetLocationId], references: [id])
  createdBy           User?               @relation("TaskCreator", fields: [createdById], references: [id])
  completedBy         User?               @relation("TaskCompleter", fields: [completedById], references: [id])
  lines               WarehouseTaskLine[]

  @@index([status])
  @@index([createdAt])
  @@index([productId])
  @@index([buyer])
  @@index([articleNumber])
}

model WarehouseTaskLine {
  id                  String         @id @default(cuid())
  taskId              String
  productId           String
  expectedQty         Int
  articleNumber       String?
  productNameSnapshot String?
  targetLocationId    String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  task                WarehouseTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  product             Product        @relation(fields: [productId], references: [id])
  targetLocation      Location?      @relation(fields: [targetLocationId], references: [id])

  @@index([taskId])
  @@index([productId])
  @@index([articleNumber])
  @@index([targetLocationId])
}
